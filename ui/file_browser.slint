import { Theme } from "theme.slint";
import { ScrollView } from "std-widgets.slint";
export struct FileEntry {
    name: string,
    path: string,
    is-dir: bool,
    size: string,
    modified: string,
}

export component FileBrowser inherits Rectangle {
    in property <string> current-path: "/";
    in property <[FileEntry]> entries;
    in property <[string]> history: [];
    in property <string> status: "";
    in property <bool> loading: false;
    in property <bool> can-go-back: false;
    in property <bool> compact: false;
    in property <bool> lang-en: true;

    callback navigate(string);
    callback go-up();
    callback go-back();
    callback refresh();
    callback file-drag-start(string /* path */, string /* name */, bool /* is_dir */, length /* abs-x */, length /* abs-y */);
    callback file-drag-pos(length /* abs-x */, length /* abs-y */);
    callback file-drag-end(length /* abs-x */, length /* abs-y */);

    background: Theme.bg-panel;

    VerticalLayout {
        spacing: 0;

        // --- Path bar ---
        Rectangle {
            height: 28px;
            background: Theme.bg-panel-alt;
            HorizontalLayout {
                padding-left: 6px;
                padding-right: 4px;
                spacing: 4px;

                Text {
                    text: "\u{E2C7}";
                    font-family: "Material Icons";
                    color: Theme.text-secondary;
                    font-size: Theme.fs-sm;
                    vertical-alignment: center;
                    width: 18px;
                }

                Rectangle {
                    horizontal-stretch: 1;
                    height: 20px;
                    border-radius: Theme.radius-sm;
                    background: Theme.bg-root;
                    border-width: 1px;
                    border-color: path-in.has-focus ? Theme.accent : Theme.border-subtle;
                    path-in := TextInput {
                        x: 4px;
                        width: parent.width - 8px;
                        height: parent.height;
                        text: root.current-path;
                        color: Theme.text-primary;
                        font-size: Theme.fs-xs;
                        vertical-alignment: center;
                        single-line: true;
                        accepted => { root.navigate(self.text); }
                    }
                }

                Rectangle {
                    width: 18px; height: 20px;
                    border-radius: Theme.radius-sm;
                    background: hist-ta.has-hover ? Theme.bg-hover : transparent;
                    hist-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { his-popup.show(); }
                    }
                    Text {
                        text: "\u{E5CF}";
                        font-family: "Material Icons";
                        color: Theme.text-secondary;
                        font-size: 10px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    his-popup := PopupWindow {
                        x: 0; y: parent.height + 2px;
                        width: 180px;
                        Rectangle {
                            background: Theme.bg-panel;
                            border-radius: Theme.radius-sm;
                            border-width: 1px;
                            border-color: Theme.border-strong;
                            drop-shadow-blur: 10px;
                            drop-shadow-color: #00000050;
                            VerticalLayout {
                                padding: 4px;
                                spacing: 1px;
                                for h in root.history : Rectangle {
                                    height: 22px;
                                    border-radius: 3px;
                                    background: h-ta.has-hover ? Theme.bg-hover : transparent;
                                    h-ta := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { root.navigate(h); }
                                    }
                                    Text {
                                        x: 6px;
                                        text: h;
                                        color: Theme.text-primary;
                                        font-size: Theme.fs-xs;
                                        vertical-alignment: center;
                                        height: parent.height;
                                        overflow: elide;
                                        width: parent.width - 12px;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        // --- Toolbar ---
        Rectangle {
            height: 24px;
            background: Theme.bg-panel;
            HorizontalLayout {
                padding-left: 6px;
                spacing: 2px;

                Rectangle {
                    width: 22px; height: 18px;
                    border-radius: 3px;
                    background: back-ta.has-hover && root.can-go-back ? Theme.bg-hover : transparent;
                    back-ta := TouchArea {
                        mouse-cursor: root.can-go-back ? pointer : default;
                        clicked => { if root.can-go-back { root.go-back(); } }
                    }
                    Text {
                        text: "\u{E5C4}";
                        font-family: "Material Icons";
                        color: root.can-go-back ? Theme.text-secondary : Theme.text-muted;
                        font-size: 12px;
                        horizontal-alignment: center; vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: 22px; height: 18px;
                    border-radius: 3px;
                    background: up-ta.has-hover ? Theme.bg-hover : transparent;
                    up-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.go-up(); }
                    }
                    Text {
                        text: "\u{E5D8}";
                        font-family: "Material Icons";
                        color: Theme.text-secondary;
                        font-size: 12px;
                        horizontal-alignment: center; vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: 22px; height: 18px;
                    border-radius: 3px;
                    background: ref-ta.has-hover ? Theme.bg-hover : transparent;
                    ref-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.refresh(); }
                    }
                    Text {
                        text: "\u{E5D5}";
                        font-family: "Material Icons";
                        color: Theme.text-secondary;
                        font-size: 12px;
                        horizontal-alignment: center; vertical-alignment: center;
                    }
                }

                Rectangle { horizontal-stretch: 1; }
            }
        }
        Rectangle { height: 1px; background: Theme.border-subtle; }

        // --- File list ---
        Rectangle {
            vertical-stretch: 1;
            clip: true;
            ScrollView {
                width: parent.width;
                height: parent.height;
                viewport-width: self.visible-width;
                viewport-height: max(self.visible-height, flist.preferred-height);

                flist := VerticalLayout {
                    spacing: 0;

                    if root.loading : Rectangle {
                        height: 32px;
                        Text {
                            text: "Loading...";
                            color: Theme.text-muted; font-size: Theme.fs-xs;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                    }

                    if !root.loading && root.entries.length == 0 : Rectangle {
                        height: 32px;
                        Text {
                            text: root.lang-en ? "Empty directory" : "空目录";
                            color: Theme.text-muted; font-size: Theme.fs-xs;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                    }

                    for entry[i] in root.entries : Rectangle {
                        height: 22px;
                        background: ta.has-hover ? #4a90e225 : (mod(i, 2) == 0 ? transparent : #ffffff08);

                        ta := TouchArea {
                            mouse-cursor: pointer;
                            property <bool> dnd-pressing: false;
                            property <bool> dnd-active: false;
                            property <length> dnd-press-x;
                            property <length> dnd-press-y;
                            pointer-event(ev) => {
                                if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left) {
                                    dnd-pressing = true;
                                    dnd-press-x = self.absolute-position.x + self.mouse-x;
                                    dnd-press-y = self.absolute-position.y + self.mouse-y;
                                } else if (ev.kind == PointerEventKind.up) {
                                    if dnd-active {
                                        root.file-drag-end(self.absolute-position.x + self.mouse-x,
                                                          self.absolute-position.y + self.mouse-y);
                                        dnd-active = false;
                                    }
                                    dnd-pressing = false;
                                }
                            }
                            moved => {
                                if dnd-pressing {
                                    let cx = self.absolute-position.x + self.mouse-x;
                                    let cy = self.absolute-position.y + self.mouse-y;
                                    if Math.abs(cx - dnd-press-x) > 5px || Math.abs(cy - dnd-press-y) > 5px {
                                        dnd-pressing = false;
                                        dnd-active = true;
                                        root.file-drag-start(entry.path, entry.name, entry.is-dir, cx, cy);
                                    }
                                } else if dnd-active {
                                    root.file-drag-pos(self.absolute-position.x + self.mouse-x,
                                                      self.absolute-position.y + self.mouse-y);
                                }
                            }
                            clicked => { }
                            double-clicked => {
                                if entry.is-dir {
                                    root.navigate(entry.path);
                                }
                            }
                        }

                        HorizontalLayout {
                            padding-left: 6px;
                            padding-right: 6px;
                            spacing: 4px;
                            Text {
                                text: entry.is-dir ? "\u{E2C7}" : "\u{E24D}";
                                font-family: "Material Icons";
                                color: entry.is-dir ? Theme.accent : Theme.text-secondary;
                                font-size: 12px;
                                width: 16px;
                                vertical-alignment: center;
                            }
                            Text {
                                text: entry.name;
                                color: entry.is-dir ? Theme.accent : Theme.text-primary;
                                font-size: Theme.fs-xs;
                                horizontal-stretch: 1;
                                overflow: elide;
                                vertical-alignment: center;
                            }
                            if !root.compact : Text {
                                text: entry.is-dir ? "" : entry.size;
                                color: Theme.text-secondary;
                                font-size: Theme.fs-xs;
                                width: 60px;
                                horizontal-alignment: right;
                                vertical-alignment: center;
                            }
                        }
                    }

                    Rectangle { vertical-stretch: 1; }
                }
            }
        }

        // --- Status bar ---
        Rectangle {
            height: 18px;
            background: Theme.bg-panel-alt;
            visible: root.status != "";
            Text {
                x: 6px;
                text: root.status;
                color: Theme.text-muted;
                font-size: Theme.fs-xs;
                vertical-alignment: center;
                height: parent.height;
                overflow: elide;
                width: parent.width - 12px;
            }
        }
    }
}
