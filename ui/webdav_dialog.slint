import { Theme } from "theme.slint";
import { LabeledInput, PrimaryButton, GhostButton } from "widgets.slint";

// 关闭按钮组件（Material Icons 关闭图标，hover 时变红）
component CloseButton inherits Rectangle {
    callback clicked();
    width: 28px;
    height: 28px;
    border-radius: Theme.radius-sm;
    background: touch.has-hover ? Theme.danger.with-alpha(0.15) : transparent;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    Text {
        text: "\u{E5CD}";               // Material Icons close
        font-family: "Material Icons";
        color: touch.has-hover ? Theme.danger : Theme.text-muted;
        font-size: 18px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// WebDAV 同步设置对话框
// Toast 提示由外部 AppWindow 控制（不在此组件内）
export component WebDavDialog inherits Rectangle {
    // ── 对外属性 ──
    in-out property <bool> open: false;
    in-out property <string> url: "";
    in-out property <string> username: "";
    in-out property <string> password: "";
    in-out property <bool> enabled: false;
    in-out property <bool> auto-sync: false;
    in-out property <bool> busy: false;

    // ── 对外回调 ──
    callback test-connection();
    callback upload();
    callback download();
    callback save(string, string, string, bool, bool);
    callback cancel();

    visible: open;
    width: 100%;
    height: 100%;
    background: #00000060;

    // 对话框主体
    dialog-box := Rectangle {
        width: parent.width.min(420px).max(320px) - 32px;
        height: parent.height.min(420px) - 32px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        border-radius: Theme.radius-lg;
        background: Theme.bg-panel;
        border-width: 1px;
        border-color: Theme.border-subtle;

        VerticalLayout {
            padding: 20px;
            spacing: 12px;

            // ── 标题栏 ──
            HorizontalLayout {
                height: 28px;
                spacing: 8px;

                Text {
                    text: "WebDAV 同步";
                    font-size: Theme.fs-xl;
                    color: Theme.text-primary;
                    font-weight: 700;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                CloseButton {
                    clicked => { root.cancel(); }
                }
            }

            // ── 分割线 ──
            Rectangle {
                height: 1px;
                background: Theme.border-subtle;
            }

            // ── 表单区域 ──
            VerticalLayout {
                spacing: 12px;

                LabeledInput {
                    label: "服务器地址";
                    placeholder: "https://dav.jianguoyun.com/dav/your-path/";
                    value <=> root.url;
                }

                LabeledInput {
                    label: "用户名";
                    placeholder: "坚果云邮箱";
                    value <=> root.username;
                }

                LabeledInput {
                    label: "应用密码";
                    placeholder: "第三方应用专用密码（非登录密码）";
                    value <=> root.password;
                    password: true;
                }

                // ── 开关选项 ──
                HorizontalLayout {
                    spacing: 16px;
                    height: 32px;

                    // 启用同步
                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;
                        horizontal-stretch: 1;

                        Rectangle {
                            width: 18px;
                            height: 18px;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: root.enabled ? Theme.accent : Theme.border-subtle;
                            background: root.enabled ? Theme.accent : Theme.bg-root;
                            y: (parent.height - self.height) / 2;
                            TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.enabled = !root.enabled; }
                            }
                            if root.enabled : Text {
                                text: "✓";
                                color: white;
                                font-size: 11px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        Text {
                            text: "启用同步";
                            color: Theme.text-primary;
                            font-size: Theme.fs-sm;
                            vertical-alignment: center;
                        }
                    }

                    // 自动同步
                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;
                        horizontal-stretch: 1;

                        Rectangle {
                            width: 18px;
                            height: 18px;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: root.auto-sync ? Theme.accent : Theme.border-subtle;
                            background: root.auto-sync ? Theme.accent : Theme.bg-root;
                            y: (parent.height - self.height) / 2;
                            TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.auto-sync = !root.auto-sync; }
                            }
                            if root.auto-sync : Text {
                                text: "✓";
                                color: white;
                                font-size: 11px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        Text {
                            text: "自动同步";
                            color: Theme.text-primary;
                            font-size: Theme.fs-sm;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            // ── 弹性空间（把按钮推到底部） ──
            Rectangle { vertical-stretch: 1; }

            // ── 分割线 ──
            Rectangle {
                height: 1px;
                background: Theme.border-subtle;
            }

            // ── 按钮栏 ──
            HorizontalLayout {
                spacing: 8px;
                height: 36px;

                GhostButton {
                    text: root.busy ? "测试中..." : "测试连接";
                    clicked => { root.test-connection(); }
                }

                Rectangle { horizontal-stretch: 1; }

                GhostButton {
                    text: "上传";
                    clicked => { root.upload(); }
                }

                GhostButton {
                    text: "下载";
                    clicked => { root.download(); }
                }

                PrimaryButton {
                    text: "保存";
                    clicked => {
                        root.save(root.url, root.username, root.password, root.enabled, root.auto-sync);
                    }
                }
            }
        }
    }
}
